TWINTEST_PORT = "3300"
TWINTEST_OFFER_PROFILE = "freemium"
TWINTEST_API_KEY = "replace-with-freemium-master-key"

TWINTEST_STORE_BACKEND = "sqlite"
TWINTEST_DATABASE_FILE = "./data/twintest-freemium.sqlite"
TWINTEST_RUN_MODE = "external"

TWINTEST_ARTIFACT_STORE_BACKEND = "local_filesystem"
TWINTEST_ARTIFACT_ROOT = "./data/artifacts"

TWINTEST_BILLING_PROVIDER = "manual"
TWINTEST_BILLING_WEBHOOK_SECRET = "replace-with-freemium-webhook-secret"
TWINTEST_BILLING_WEBHOOK_MODE = "hmac_sha256"

TWINTEST_RATE_LIMIT_ENABLED = "true"
TWINTEST_RATE_LIMIT_MAX_REQUESTS = "300"
TWINTEST_RATE_LIMIT_WINDOW_SECONDS = "60"
TWINTEST_AUTH_LOCKOUT_THRESHOLD = "4"
TWINTEST_AUTH_LOCKOUT_WINDOW_SECONDS = "600"
TWINTEST_AUTH_LOCKOUT_DURATION_SECONDS = "900"

# Optional AI autobind (freemium plan keeps aiAutobind disabled by limits)
TWINTEST_AI_PROVIDER = "groq"
TWINTEST_AI_API_KEY = ""
TWINTEST_AI_MODEL = "openai/gpt-oss-120b"
